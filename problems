راه مطمئن‌تر (بر اساس شناسه، نه اندیس): اگه نسخه MySQL جدید باشه:

UPDATE app_store
SET v = JSON_REMOVE(
  v,
  REPLACE(JSON_UNQUOTE(JSON_SEARCH(v, 'one', 'PUR-492940')), '.id', '')
)
WHERE k = 'main';
Copy
